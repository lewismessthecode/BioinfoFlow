/*
 * Local overrides for the Bioinfoflow nf-core/rnaseq launch demo.
 *
 * The upstream nf-core `test` profile supplies the small test inputs. This file
 * keeps local resource usage modest for fresh laptops and CI-like smoke runs.
 */

process {
  cpus = { Math.min(task.cpus as int, 2) }
  memory = { task.memory ? task.memory : 4.GB }
  time = { task.time ? task.time : 2.h }
}

docker {
  enabled = true
}
