# Optional backend-only overrides.
#
# Default local development now reads ../.env automatically.
# Only create backend/.env if this machine needs backend-specific overrides
# that should not live in the shared repo-root .env.
#
# Common examples:
# BIOINFOFLOW_HOME=/absolute/path/to/bpiper-data
# DATABASE_URL=sqlite+aiosqlite:////absolute/path/to/bioinfoflow.db
# NEXTFLOW_BIN=/absolute/path/to/nextflow
# MINIWDL_BIN=/absolute/path/to/miniwdl
# DOCKER_SOCKET=unix:///var/run/docker.sock
