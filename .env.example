# ============================================================
# Bioinfoflow — Shared Environment Template
# ============================================================
#
# This is the default source of truth for both Docker and local development.
#
# Recommended setup:
#   1. cp .env.example .env
#   2. Edit .env — set at least one AI API key and owner credentials.
#      For localhost Docker, BETTER_AUTH_SECRET may stay empty.
#   3. Docker: docker compose up -d --build
#      Local dev: backend/ and frontend/ both auto-read ../.env
#
# Optional overrides:
#   - backend/.env          backend-only local override
#   - frontend/.env.local   frontend-only local override
#
# Precedence:
#   shell env > package-local override > this file > code defaults
#
# ============================================================

# ── Platform Root ──────────────────────────────────────────────
# Absolute path where all platform data lives (database, projects, outputs).
# For local Docker, leave this unset to use this repo's ./data directory.
# The backend creates the required platform subdirectories on startup.
# For Docker Compose the path is identity-mounted (host path == container path).
# Local Docker default if unset: ${PWD}/data
# BIOINFOFLOW_HOME=${PWD}/data
# Optional Debian mirror override for backend image builds in slow/restricted networks.
# APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn
# Examples:
# BIOINFOFLOW_HOME=/srv/bioinfoflow        # Linux server
# BIOINFOFLOW_HOME=/Users/<you>/bioinfoflow-data  # macOS
# BIOINFOFLOW_HOME=/lustre/<user>/bioinfoflow    # HPC
# BIOINFOFLOW_HOME=/mnt/efs/bioinfoflow        # cloud NFS

# ── Ports ──────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ── Pre-built container images (optional) ─────────────────────
# Use with docker-compose.prod.yml for the localhost quick start:
#   IMAGE_REGISTRY=ghcr.io/lewismessthecode
#   IMAGE_TAG=latest
# Leave unset when building from source with docker-compose.yml.
# IMAGE_REGISTRY=ghcr.io/lewismessthecode
# IMAGE_TAG=latest

# ── Authentication ─────────────────────────────────────────────
# Mode: "personal" (single user), "team" (multi-user), "dev" (no auth)
AUTH_MODE=personal

# First-time owner credentials — auto-created on first startup.
# ⚠️  Change these before deploying!
AUTH_BOOTSTRAP_OWNER_EMAIL=admin@example.com
AUTH_BOOTSTRAP_OWNER_PASSWORD=changeme

# Secret for signing auth tokens.
# Localhost Docker and local `bun run dev` can leave this empty. Bioinfoflow
# generates a persistent local secret under BIOINFOFLOW_HOME/state/auth.
# Set a strong random value before running a shared or remote deployment:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Self-signup: set to true to allow new users to register (useful in team mode).
AUTH_SELF_SIGNUP_ENABLED=false

# ── AI Agent ───────────────────────────────────────────────────
# At least one API key is required for the AI agent to work.
# The agent auto-selects the provider based on available keys.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=

# Optional: declare additional OpenAI-compatible endpoint profiles.
# This supports multiple local/gateway endpoints without adding code.
# Each profile becomes a selectable provider id.
# OPENAI_COMPATIBLE_PROVIDERS='[
#   {
#     "id": "ollama-deepseek",
#     "label": "Ollama DeepSeek",
#     "base_url": "http://127.0.0.1:11434/v1",
#     "api_key": "ollama",
#     "default_model": "deepseek-r1:latest",
#     "models": ["deepseek-r1:latest"]
#   },
#   {
#     "id": "lmstudio",
#     "label": "LM Studio",
#     "base_url": "http://127.0.0.1:1234/v1",
#     "api_key": "lm-studio",
#     "models": ["local-model"]
#   }
# ]'

# Agent model override (optional)
# AGENT_MODEL=claude-sonnet-4-6
# Agent engine: "legacy" or "hermes_service"
# AGENT_ENGINE=hermes_service
# Managed Hermes home (optional)
# AGENT_HERMES_HOME=~/.bioinfoflow/hermes
# Legacy compatibility alias for the SessionDB file.
# If set, Bioinfoflow will treat its parent directory as AGENT_HERMES_HOME.
# AGENT_HERMES_STATE_DB=~/.bioinfoflow/hermes/state.db
# AGENT_HERMES_MAX_CONCURRENCY=4

# ── URLs ───────────────────────────────────────────────────────
# ⚠️  NEXT_PUBLIC_* values are baked into the frontend at BUILD time.
#     Changing them requires a rebuild: docker compose up -d --build
#
# For local Docker:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
BETTER_AUTH_URL=http://localhost:3000
#
# For remote deployment, change to your server's address:
# NEXT_PUBLIC_API_BASE_URL=http://YOUR_SERVER_IP:8000/api/v1
# BETTER_AUTH_URL=http://YOUR_SERVER_IP:3000

# ── CORS ───────────────────────────────────────────────────────
# Must match the frontend URL. For remote deployment, update this too.
CORS_ORIGINS=["http://localhost:3000"]
# CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
# Host header allowlist for the backend. Add your public backend hostname/IP
# before exposing the app outside localhost.
# TRUSTED_HOSTS=["localhost","127.0.0.1","YOUR_SERVER_IP_OR_DOMAIN"]

# ── Docker Socket ──────────────────────────────────────────────
# Required for workflow execution (Nextflow/WDL run containers via Docker).
# ⚠️  Security: mounting the Docker socket gives the backend container
#     full access to the host's Docker daemon. Only expose on trusted networks.
# DOCKER_SOCKET=unix:///var/run/docker.sock

# ── Advanced (usually no need to change) ───────────────────────
# APP_NAME=Bioinfoflow
# DEBUG=false
# RUN_SCHEDULER_MODE=persistent
# SCHEDULER_TOTAL_SLOTS=0
# SCHEDULER_MAX_WORKERS=0
# SCHEDULER_MAX_CONCURRENCY=4
# SCHEDULER_MAX_QUEUE_DEPTH=500
# SCHEDULER_POLL_INTERVAL=1.0
# SCHEDULER_STALE_TIMEOUT_MINUTES=30
# SCHEDULER_RESOURCE_CHECK_ENABLED=true
# SCHEDULER_RESOURCE_SAMPLE_INTERVAL=30.0
# SCHEDULER_SAFETY_CPU=2
# SCHEDULER_SAFETY_MEMORY_GB=2.0
# SCHEDULER_SAFETY_DISK_GB=10.0
# SCHEDULER_WORKER_HEARTBEAT_GRACE_SECONDS=90
# AGENT_MAX_ROUNDS=50
# AGENT_OBSERVABILITY=true
