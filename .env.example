# ============================================================
# Bioinfoflow — Shared Environment Template
# ============================================================
#
# This optional file customizes Docker and local development defaults.
#
# Zero-configuration localhost setup:
#   docker compose up -d --build
#
# Optional customization:
#   1. cp .env.example .env
#   2. Edit only the values you want to override.
#
# Local defaults use dev auth and loopback-only port bindings. Before exposing
# Bioinfoflow to a network, switch to personal or team auth and configure the
# deployment-specific credentials, secrets, URLs, CORS origins, and hosts.
#
# Optional overrides:
#   - backend/.env          backend-only local override
#   - frontend/.env.local   frontend-only local override
#
# Precedence:
#   shell env > package-local override > this file > code defaults
#
# ============================================================

# ── Platform Root ──────────────────────────────────────────────
# Absolute path where all platform data lives (database, projects, outputs).
# For local Docker, leave this unset to use this repo's ./data directory.
# The backend creates the required platform subdirectories on startup.
# For Docker Compose the path is identity-mounted (host path == container path).
# Local Docker default if unset: ${PWD}/data
# BIOINFOFLOW_HOME=${PWD}/data
# Optional Debian mirror override for backend image builds in slow/restricted networks.
# APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn
# Examples:
# BIOINFOFLOW_HOME=/srv/bioinfoflow        # Linux server
# BIOINFOFLOW_HOME=/Users/<you>/bioinfoflow-data  # macOS
# BIOINFOFLOW_HOME=/lustre/<user>/bioinfoflow    # HPC
# BIOINFOFLOW_HOME=/mnt/efs/bioinfoflow        # cloud NFS
# Optional Agent Skills directory. Defaults to <BIOINFOFLOW_HOME>/skills.
# Docker users should keep this under BIOINFOFLOW_HOME unless adding a matching
# bind mount for the custom path.
# BIOINFOFLOW_SKILLS_ROOT=/Users/<you>/bioinfoflow-data/skills

# ── Ports ──────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ── Pre-built container images (optional) ─────────────────────
# Use with docker-compose.prod.yml for the localhost quick start:
#   IMAGE_REGISTRY=ghcr.io/lewismessthecode
#   IMAGE_TAG=latest
# Leave unset when building from source with docker-compose.yml.
# IMAGE_REGISTRY=ghcr.io/lewismessthecode
# IMAGE_TAG=latest

# ── Authentication ─────────────────────────────────────────────
# Mode: "personal" (single user), "team" (multi-user), "dev" (no auth).
# Dev mode is safe only while the services remain bound to localhost.
AUTH_MODE=dev

# First-time owner credentials for personal or team mode. Uncomment and replace
# both values before a shared or remote deployment.
# AUTH_BOOTSTRAP_OWNER_EMAIL=admin@example.com
# AUTH_BOOTSTRAP_OWNER_PASSWORD=replace-with-a-strong-password

# Secret for signing auth tokens.
# Localhost Docker and local `bun run dev` can leave this empty. Bioinfoflow
# generates a persistent local secret under BIOINFOFLOW_HOME/state/auth.
# Set a strong random value before running a shared or remote deployment:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Stable encryption secret for UI-stored provider and registry credentials.
# Required in AUTH_MODE=team when using Stored credentials for AI Providers or
# Container Registries. Generate once, keep it stable, and back it up:
#   openssl rand -hex 32
# After adding/changing this for Docker Compose, recreate the backend container:
#   docker compose up -d --force-recreate backend
BIOINFOFLOW_CREDENTIAL_KEY=

# Self-signup: set to true to allow new users to register (useful in team mode).
AUTH_SELF_SIGNUP_ENABLED=false

# ── AI Providers / Agent ────────────────────────────────────────
# The UI is the primary configuration surface:
#   Settings -> AI Providers
# Values here only bootstrap the catalog for fresh/headless deployments.
# User-saved UI configuration takes precedence over these environment defaults.
#
# Cloud providers: paste a key in the UI, or set one here to bootstrap.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# XAI_API_KEY=
# GROK_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# KIMI_API_KEY=        # Kimi global platform: api.moonshot.ai
# KIMI_CN_API_KEY=     # Kimi China platform: api.moonshot.cn
# MOONSHOT_CN_API_KEY= # Alias for Kimi China platform
# MOONSHOT_API_KEY=    # Legacy Kimi China alias; prefer KIMI_CN_API_KEY
# DASHSCOPE_API_KEY=
# QWEN_API_KEY=
# MISTRAL_API_KEY=
# COHERE_API_KEY=
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=
# PERPLEXITY_API_KEY=

# Local and gateway providers.
# Ollama can usually be configured in the UI with just this endpoint.
# OLLAMA_BASE_URL=http://localhost:11434

# vLLM simple bootstrap for the common "one vLLM endpoint, one served model"
# deployment. Point VLLM_BASE_URL at your server's OpenAI-compatible endpoint
# (note the /v1 suffix). VLLM_API_KEY is only needed if you started vLLM with
# --api-key. VLLM_MODEL should match the server's --served-model-name; you can
# omit it when the endpoint's /v1/models list is reachable (models are then
# discovered automatically).
# VLLM_BASE_URL=http://<vllm-host>:<port>/v1
# VLLM_API_KEY=<served-api-key>
# VLLM_MODEL=<served-model-id>

# Generic OpenAI-compatible bootstrap for LM Studio, local gateways, or hosted
# providers not yet listed in the UI template catalog.
# OPENAI_COMPATIBLE_NAME=Local Gateway
# OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:1234/v1
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_MODEL=local-model

# ── Voice dictation (optional) ────────────────────────────────
# Bioinfoflow calls an OpenAI-compatible /v1/audio/transcriptions endpoint and
# probes /v1/models to verify the configured model before enabling the mic.
# Empty ASR_BASE_URL keeps voice input disabled. There is no automatic cloud
# fallback and only the selected local profile should be started.
#
# Chinese/Linux Fun-ASR:
# ASR_PROVIDER=funasr
# ASR_BASE_URL=http://asr-funasr:8000
# ASR_MODEL=FunAudioLLM/Fun-ASR-Nano-2512
# ASR_DEVICE=cuda
# docker compose --profile voice-funasr up -d --build asr-funasr backend frontend
#
# macOS/general CPU faster-whisper:
# ASR_PROVIDER=whisper
# ASR_BASE_URL=http://asr-whisper:8000
# ASR_MODEL=large-v3-turbo
# ASR_DEVICE=cpu
# ASR_COMPUTE_TYPE=int8
# docker compose --profile voice-whisper up -d --build asr-whisper backend frontend
#
# Explicit cloud example:
# ASR_PROVIDER=openai
# ASR_BASE_URL=https://api.openai.com
# ASR_MODEL=gpt-4o-mini-transcribe
# ASR_API_KEY=
#
# ASR_LANGUAGE=zh
# ASR_CONTEXT_TERMS=["Bioinfoflow","Nextflow","MiniWDL","FASTQ"]

# Agent engine: "legacy" or "hermes_service"
# AGENT_ENGINE=hermes_service
# Managed Hermes home (optional)
# AGENT_HERMES_HOME=~/.bioinfoflow/hermes
# Legacy compatibility alias for the SessionDB file.
# If set, Bioinfoflow will treat its parent directory as AGENT_HERMES_HOME.
# AGENT_HERMES_STATE_DB=~/.bioinfoflow/hermes/state.db
# AGENT_HERMES_MAX_CONCURRENCY=4

# ── URLs ───────────────────────────────────────────────────────
# ⚠️  NEXT_PUBLIC_* values are baked into the frontend at BUILD time.
#     Changing them requires a rebuild: docker compose up -d --build
#
# For local Docker:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
BETTER_AUTH_URL=http://localhost:3000
#
# For remote deployment, change to your server's address:
# NEXT_PUBLIC_API_BASE_URL=http://YOUR_SERVER_IP:8000/api/v1
# BETTER_AUTH_URL=http://YOUR_SERVER_IP:3000

# ── CORS ───────────────────────────────────────────────────────
# Must match the frontend URL. For remote deployment, update this too.
CORS_ORIGINS=["http://localhost:3000"]
# CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
# Host header allowlist for the backend. Add your public backend hostname/IP
# before exposing the app outside localhost.
# TRUSTED_HOSTS=["localhost","127.0.0.1","YOUR_SERVER_IP_OR_DOMAIN"]

# ── Docker Socket ──────────────────────────────────────────────
# Required for workflow execution (Nextflow/WDL run containers via Docker).
#
# ── GPU discovery ──────────────────────────────────────────────
# Default: automatically ask Docker which NVIDIA GPUs the host can expose.
# This works with the normal `docker compose up -d --build` command when the
# Linux host has NVIDIA drivers and NVIDIA Container Toolkit installed.
BIOINFOFLOW_GPU_MODE=auto
BIOINFOFLOW_GPU_DEVICES=all
# To allow only a subset, prefer stable UUIDs from `nvidia-smi -L`:
# BIOINFOFLOW_GPU_MODE=manual
# BIOINFOFLOW_GPU_DEVICES=GPU-aaaaaaaa-...,GPU-bbbbbbbb-...
# Numeric indices are accepted but UUIDs remain stable if device ordering changes.
# Disable all GPU probing and GPU workflow capacity:
# BIOINFOFLOW_GPU_MODE=disabled
# After changing GPU policy, apply it with:
# docker compose up -d --build --force-recreate backend
# ⚠️  Security: mounting the Docker socket gives the backend container
#     full access to the host's Docker daemon. Only expose on trusted networks.
# DOCKER_SOCKET=unix:///var/run/docker.sock

# ── Advanced (usually no need to change) ───────────────────────
# APP_NAME=Bioinfoflow
# DEBUG=false
# SCHEDULER_TOTAL_SLOTS=0
# SCHEDULER_MAX_WORKERS=0
# SCHEDULER_MAX_CONCURRENCY=4
# SCHEDULER_MAX_QUEUE_DEPTH=500
# SCHEDULER_POLL_INTERVAL=1.0
# SCHEDULER_STALE_TIMEOUT_MINUTES=30
# SCHEDULER_RESOURCE_CHECK_ENABLED=true
# SCHEDULER_RESOURCE_SAMPLE_INTERVAL=30.0
# SCHEDULER_SAFETY_CPU=2
# SCHEDULER_SAFETY_MEMORY_GB=2.0
# SCHEDULER_SAFETY_DISK_GB=10.0
# SCHEDULER_WORKER_HEARTBEAT_GRACE_SECONDS=90
# AGENT_MAX_ITERATIONS=90
# AGENT_OBSERVABILITY=true
# Maximum wall-clock duration for one model request attempt, including streams.
# AGENT_MODEL_ATTEMPT_TIMEOUT_SECONDS=120
# OS-level sandbox for the agent bash tool (bubblewrap on Linux, sandbox-exec on
# macOS). Off by default; when on, bash is confined to the repo + data home with
# the network disabled. See docker-compose.yml notes for running bwrap in Docker.
# AGENT_SANDBOX_ENABLED=false
# AGENT_SANDBOX_FAIL_CLOSED=true
# AGENT_SANDBOX_ALLOW_NETWORK=false
# AGENT_SANDBOX_ALLOW_UNSANDBOXED=false
# Enable Vercel Analytics explicitly for non-Vercel builds.
NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS=false
